// Convierte este schema de Prisma a formato database.build, incluyendo:
// - Todas las tablas con sus columnas y tipos de datos
// - Claves primarias (pk)
// - Claves foráneas (fk) con sus relaciones
// - Campos únicos (unique)
// - Valores por defecto cuando sean relevantes
// - Omite de las tablas los valores createdAt y updatedAt
// - Los enums como tablas de referencia

// -------------------------------------------
// refactoriza el orden de las tablas para que la creacion
// de las tablas se hagan en el orden correcto
// -------------------------------------------
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AccionesBitacora {
  LOGIN
  CREATE_ADMIN
  CREATE_USER
  UPDATE_ADMIN
  UPDATE_USER
  DELETE_ADMIN
  DELETE_USER
  VIEW
  ERROR
  GET_USUARIOS

  CREAR_PLAN_SUSCRIPCION
  UPDATE_PLAN_SUSCRIPCION

  CREAR_SUSCRIPCION
  VALIDAR_SUSCRIPCION
  RECHAZAR_SUSCRIPCION
  VENCIADA_SUSCRIPCION

  GENERACION_CARNET
  GENERACION_CARNET_PONENTE
  GENERACION_SOLVENCIA_PAGO
  GENERACION_COMPROBANTE_PAGO
  GENERACION_CERTIFICADO_TALLER
  GENERACION_CERTIFICADO_DIPLOMADO
  GENERACION_CERTIFICADO_CONGRESO
}

enum Rol {
  SUPER_USUARIO
  ADMINISTRADOR

  AGREMIADO_SOLVENTE
  AGREMIADO_INSOLVENTE
  PROFESOR
  ESTUDIANTE
  VISITANTE
}

enum TipoAutoridad {
  PRESIDENTE
  VICEPRESIDENTE
}

enum TipoEvento {
  TALLER
  DIPLOMADO
  CONGRESO
}

enum TipoSuscripcion {
  AGREMIADO
  ESTUDIANTE
  PROFESOR
}

enum EstatusSuscripcion {
  PENDIENTE
  VALIDADO
  VENCIDO
  RECHAZADA
}

enum NivelAcademico {
  LICENCIADO
  TSU
}

enum TipoDeDocumento {
  CARNET
  CARNET_PONENTE
  SOLVENCIA_PAGO
  COMPROBANTE_PAGO
  CERTIFICADO_TALLER
  CERTIFICADO_DIPLOMADO
  CERTIFICADO_CONGRESO
}

// ─── Nivel 1: sin dependencias ────────────────────────────────────────────────

model Usuario {
  id              Int     @id @default(autoincrement())
  primerNombre    String
  segundoNombre   String?
  primerApellido  String
  segundoApellido String?
  avatar          String?
  telefono        String
  cedula          String  @unique
  email           String  @unique
  password        String
  rol             Rol     @default(VISITANTE)

  autoridad            Autoridad[]
  gremio               Gremio?
  bitacora             Bitacora[]
  evento               Evento[]
  ponente_Evento       Ponente_Evento[]
  suscripcionEventos   Suscripcion_Evento[]
  planSuscripcion      PlanSuscripcion[]
  suscripcion          Suscripcion[]
  documentoSolicitados DocumentoSolicitado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Nivel 2: dependen de Usuario ─────────────────────────────────────────────

model Autoridad {
  id            Int           @id @default(autoincrement())
  firma         String
  tipoAutoridad TipoAutoridad
  usuarioId     Int
  vigente       Boolean       @default(true)

  usuario               Usuario               @relation(fields: [usuarioId], references: [id])
  DocumentosSolicitados DocumentoSolicitado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gremio {
  id             Int            @id @default(autoincrement())
  numeroGremio   Int            @unique
  nivelAcademico NivelAcademico

  usuarioId Int     @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bitacora {
  id        Int              @id @default(autoincrement())
  type      AccionesBitacora
  fecha     DateTime         @default(now())
  mensaje   String?
  usuarioId Int
  usuario   Usuario          @relation(fields: [usuarioId], references: [id])
}

model Evento {
  id        Int        @id @default(autoincrement())
  nombre    String
  fecha     DateTime
  lugar     String
  precio    Int
  descuento Float      @default(0)
  tipo      TipoEvento
  usuarioId Int
  Usuario   Usuario    @relation(fields: [usuarioId], references: [id])

  Ponente_Evento     Ponente_Evento[]
  Suscripcion_Evento Suscripcion_Evento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Nivel 3: dependen de Usuario + Evento ────────────────────────────────────

model Ponente_Evento {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  eventoId  Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  Evento    Evento  @relation(fields: [eventoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, eventoId])
}

model Suscripcion_Evento {
  id                  Int     @id @default(autoincrement())
  precioAlSuscripcion Int
  eventoId            Int
  Evento              Evento  @relation(fields: [eventoId], references: [id])
  usuarioId           Int
  Usuario             Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, eventoId])
}

model PlanSuscripcion {
  id        Int             @id @default(autoincrement())
  costo     Int
  tipo      TipoSuscripcion
  isActivo  Boolean         @default(true)
  usuarioId Int
  Usuario   Usuario         @relation(fields: [usuarioId], references: [id])

  suscripciones Suscripcion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Suscripcion {
  id                 Int                @id @default(autoincrement())
  estatus            EstatusSuscripcion
  comprobante        Int?               @default(0)
  comprobanteImg     String
  contodesuscripcion Int
  usuarioId          Int
  usuario            Usuario            @relation(fields: [usuarioId], references: [id])
  suscripcionId      Int
  planSuscripcion    PlanSuscripcion    @relation(fields: [suscripcionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentoSolicitado {
  id          Int             @id @default(autoincrement())
  usuarioId   Int
  autoridadId Int
  tipo        TipoDeDocumento

  autoridad Autoridad @relation(fields: [autoridadId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
