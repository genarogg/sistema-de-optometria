// Convierte este schema de Prisma a formato database.build, incluyendo:
// - Todas las tablas con sus columnas y tipos de datos
// - Claves primarias (pk)
// - Claves foráneas (fk) con sus relaciones
// - Campos únicos (unique)
// - Valores por defecto cuando sean relevantes
// - Omite de las tablas los valores createdAt y updatedAt

// -------------------------------------------

// -------------------------------------------
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────
// Primero los enums, ya que los modelos los referencian

enum Rol {
  ADMIN
  ASISTENTE
  CLIENTE
}

enum AccionesBitacora {
  LOGIN
  CREATE_ADMIN
  CREATE_USER
  UPDATE_ADMIN
  UPDATE_USER
  DELETE_ADMIN
  DELETE_USER
  VIEW
  ERROR
  GET_USUARIOS
}

// ── Modelos ────────────────────────────────────────────
// Usuario va primero porque Bitacora depende de él

model Usuario {
  id             Int        @id @default(autoincrement())
  primerNombre   String
  primerApellido String
  avatar         String?
  telefono       String
  cedula         String     @unique
  email          String     @unique
  password       String
  Bitacora       Bitacora[]
  rol            Rol        @default(CLIENTE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Bitacora {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  type    AccionesBitacora
  fecha   DateTime         @default(now())
  mensaje String?
}
