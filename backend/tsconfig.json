{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020","dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fn": ["./src/func/index.ts"],
      "@fn/*": ["./src/func/*"]
    },
    "types": ["node"]
  },
  "include": ["src", "index.ts", "scripts/**/*.ts", "src/func/money"]
}
